#!/bin/bash

jq -Rs '{"query": ., "model": "claude-haiku-4.5"}' \
  | curl -s "'$1'" \
     -X 'POST' \
     -H 'Accept: application/json' \
     -H 'content-type: application/json' \
     -H 'user-id: b9ec6bcb-1ecb-4e78-a55d-96099aca3203' \
     -H 'X-prof: naanum rowdy dhaan' \
     --data-raw @- \
  | jq -rc '.message.response'
